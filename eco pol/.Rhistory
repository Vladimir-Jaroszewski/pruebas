data$change_magnitude <- sqrt((data$eje.econ2 - data$eje.econ1)^2 +
(data$eje.social2 - data$eje.social1)^2)
# Base del gráfico
ba <- ggplot(data, aes(eje.econ1, eje.social1)) +
theme_minimal() +
coord_fixed(ratio = 1, xlim = c(-10, 10), ylim = c(-10, 10)) +
geom_rect(aes(xmin = -9, xmax = 0, ymin = 0, ymax = 9), fill = "#ff7474") +
geom_rect(aes(xmin = 0, xmax = 9, ymin = 0, ymax = 9), fill = "#44aafd") +
geom_rect(aes(xmin = -9, xmax = 0, ymin = -9, ymax = 0), fill = "#98ec98") +
geom_rect(aes(xmin = 0, xmax = 9, ymin = -9, ymax = 0), fill = "#c09aea")
# Agregar puntos que varían en tamaño según la magnitud del cambio
b <- ba +
geom_segment(aes(
x = eje.econ1, y = eje.social1,
xend = eje.econ2, yend = eje.social2,
color = ballotage
), arrow = arrow(length = unit(0.2, "cm")), size = 0.7) +
geom_point(aes(size = change_magnitude, color = ballotage), alpha = 0.8) +
# Escala de colores para puntos según `ballotage`
scale_color_manual(values = c(
"Javier Milei (La Libertad Avanza)" = "blue",
"Sergio Massa (Unión por la Patria)" = "red",
"En blanco" = "grey50"
)) +
# Escala de tamaño para representar magnitud del cambio
scale_size_continuous(range = c(2, 10), name = "Magnitud del Cambio") +
# Etiquetas y títulos
labs(
x = "Eje Económico (Encuesta 1)",
y = "Eje Social (Encuesta 1)",
title = "Grado de Cambio entre Encuestas: Tamaño y Color de los Puntos"
) +
# Ajustes de tema
theme(
plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
axis.title = element_text(size = 12),
legend.position = "right"
)
# Mostrar el gráfico
plot(b)
# Base del gráfico
ba <- ggplot(data, aes(eje.econ2, eje.social2)) +
theme_minimal() +
coord_fixed(ratio = 1, xlim = c(-10, 10), ylim = c(-10, 10)) +
geom_rect(aes(xmin = -9, xmax = 0, ymin = 0, ymax = 9), fill = "#ff7474") +
geom_rect(aes(xmin = 0, xmax = 9, ymin = 0, ymax = 9), fill = "#44aafd") +
geom_rect(aes(xmin = -9, xmax = 0, ymin = -9, ymax = 0), fill = "#98ec98") +
geom_rect(aes(xmin = 0, xmax = 9, ymin = -9, ymax = 0), fill = "#c09aea")
# Agregar las flechas para mostrar el movimiento
b <- ba +
geom_segment(aes(
x = eje.econ2, y = eje.social2,
xend = eje.econ1, yend = eje.social1,
color = ballotage
), arrow = arrow(length = unit(0.2, "cm")), size = 0.7) +
geom_point(aes(color = ballotage), size = 3, shape = 19) +
scale_color_manual(values = c(
"Javier Milei (La Libertad Avanza)" = "blue",
"Sergio Massa (Unión por la Patria)" = "red",
"En blanco" = "white"
), guide = "none") +  # Ocultar la leyenda
geom_text(data = labels, aes(x = x, y = y, label = label, angle = angle),
color = "azure4") +
labs(x = "", y = "")
# Mostrar el gráfico
plot(b)

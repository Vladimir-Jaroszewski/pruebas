# Calcular diferencias en las dimensiones económicas y sociales
data$difference_econ <- data$eje.econ2 - data$eje.econ1
data$difference_social <- data$eje.social2 - data$eje.social1
# Crear un gráfico de densidad bidimensional (mapa de calor) de los cambios
ba <- ggplot(data, aes(difference_econ, difference_social)) +
theme_minimal() +
coord_fixed(ratio = 1, xlim = c(-10, 10), ylim = c(-10, 10)) +
geom_density_2d_filled(alpha = 0.8) +  # Mapa de calor basado en densidad
labs(
x = "Cambio en Eje Económico",
y = "Cambio en Eje Social",
title = "Mapa de Calor de Cambios entre Encuestas"
) +
theme(
legend.position = "right",
plot.title = element_text(hjust = 0.5, size = 14, face = "bold")
)
# Mostrar el gráfico
plot(ba)
# Calcular diferencias en las dimensiones económicas y sociales
data$difference_econ <- data$eje.econ2 - data$eje.econ1
data$difference_social <- data$eje.social2 - data$eje.social1
# Crear el gráfico con mapa de calor mejorado
ba <- ggplot(data, aes(difference_econ, difference_social)) +
theme_minimal() +
coord_fixed(ratio = 1, xlim = c(-10, 10), ylim = c(-10, 10)) +
# Mapa de calor basado en densidad
stat_density_2d(
aes(fill = ..level..), geom = "polygon", color = "white", alpha = 0.8
) +
# Escala de color mejorada para el mapa de calor
scale_fill_gradient(low = "lightblue", high = "darkblue") +
# Opcional: agregar puntos individuales para claridad
geom_point(aes(color = ballotage), size = 2, alpha = 0.8) +
# Colores para los puntos individuales
scale_color_manual(values = c(
"Javier Milei (La Libertad Avanza)" = "blue",
"Sergio Massa (Unión por la Patria)" = "red",
"En blanco" = "grey50"
)) +
# Etiquetas y títulos
labs(
x = "Cambio en Eje Económico",
y = "Cambio en Eje Social",
title = "Mapa de Calor de Cambios entre Encuestas",
fill = "Densidad",
color = "Ballotage"
) +
# Ajustes de tema
theme(
plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
axis.title = element_text(size = 12),
legend.position = "right"
)
# Mostrar el gráfico
plot(ba)
# Calcular la magnitud del cambio para cada individuo
data$change_magnitude <- sqrt((data$eje.econ2 - data$eje.econ1)^2 +
(data$eje.social2 - data$eje.social1)^2)
# Crear el gráfico con el tamaño y color de los puntos indicando el grado de cambio
ba <- ggplot(data, aes(eje.econ1, eje.social1)) +
theme_minimal() +
coord_fixed(ratio = 1, xlim = c(-10, 10), ylim = c(-10, 10)) +
geom_rect(aes(xmin = -9, xmax = 0, ymin = 0, ymax = 9), fill = "#ff7474") +
geom_rect(aes(xmin = 0, xmax = 9, ymin = 0, ymax = 9), fill = "#44aafd") +
geom_rect(aes(xmin = -9, xmax = 0, ymin = -9, ymax = 0), fill = "#98ec98") +
geom_rect(aes(xmin = 0, xmax = 9, ymin = -9, ymax = 0), fill = "#c09aea") +
# Puntos que varían en tamaño y color según el cambio
geom_point(aes(size = change_magnitude, color = ballotage), alpha = 0.8) +
# Escala de colores para los puntos según `ballotage`
scale_color_manual(values = c(
"Javier Milei (La Libertad Avanza)" = "blue",
"Sergio Massa (Unión por la Patria)" = "red",
"En blanco" = "grey50"
)) +
# Escala de tamaño para magnitud del cambio
scale_size_continuous(range = c(2, 10), name = "Magnitud del Cambio") +
# Etiquetas y títulos
labs(
x = "Eje Económico (Encuesta 1)",
y = "Eje Social (Encuesta 1)",
title = "Grado de Cambio entre Encuestas: Tamaño y Color de los Puntos"
) +
# Ajustes de tema
theme(
plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
axis.title = element_text(size = 12),
legend.position = "right"
)
# Mostrar el gráfico
plot(ba)

# Definir el contenido LaTeX
latex_code <- c(
"\\documentclass{article}",
"\\usepackage{tikz}",
"\\begin{document}",
"\\begin{center}",
"\\textbf{Timing of the game}",
"\\end{center}",
"\\begin{center}",
"\\begin{tikzpicture}",
"    % Dibuja la línea horizontal",
"    \\draw[thick] (0,0) -- (6.4,0);",
"    % Marcas en la línea de tiempo",
"    \\foreach \\x in {0, 1, 2, 3} \\draw (\\x*2, 0.1) -- (\\x*2, -0.1);",
"    % Puntos de tiempo",
"    \\node at (0, -0.3) {0};",
"    \\node at (2, -0.3) {1};",
"    \\node at (4, -0.3) {2};",
"    \\node at (6, -0.3) {3};",
"    \\node at (6.6, 0) {t};",
"    % Etiqueta de Elección y flecha",
"    \\node at (3, 1) {Elección};",
"    \\draw[->] (3, 0.8) -- (3, 0.1);",
"\\end{tikzpicture}",
"\\end{center}",
"\\end{document}"
)
# Escribir el contenido en un archivo .tex
writeLines(latex_code, "timing_of_game.tex")
pdflatex timing_of_game.tex
xelatex timing_of_game.tex
# Instalar e importar la librería magick
install.packages("magick")
# Leer el PDF y guardar como PNG
img <- image_read_pdf("timing_of_game.pdf")
# Leer el PDF y guardar como PNG
img <- image_read_pdf("timing_of_game.pdf")
library(magick)
# Leer el PDF y guardar como PNG
img <- image_read_pdf("timing_of_game.pdf")
# Instalar e importar la librería magick
install.packages("magick")
install.packages("magick")
library(magick)
# Leer el PDF y guardar como PNG
img <- image_read_pdf("timing_of_game.pdf")
image_write(img, path = "timing_of_game.png", format = "png")
# Instalar y cargar el paquete tikzDevice si no lo tienes ya instalado
install.packages("tikzDevice")
library(tikzDevice)
# Crear un archivo TikZ
tikz("grafico_tiempo.tex", width = 6, height = 3)
# Generar el gráfico de TikZ
cat("\\begin{center}\n")
cat("\\textbf{Timing of the game}\n")
cat("\\end{center}\n")
cat("\\begin{center}\n")
cat("\\begin{tikzpicture}\n")
cat("% Dibuja la línea horizontal\n")
cat("\\draw[thick] (0,0) -- (6.4,0);\n")
cat("% Marcas en la línea de tiempo\n")
cat("\\foreach \\x in {0, 1, 2, 3}\n")
cat("\\draw (\\x*2, 0.1) -- (\\x*2, -0.1);\n")
cat("% Puntos de tiempo\n")
cat("\\node at (0, -0.3) {0};\n")
cat("\\node at (2, -0.3) {1};\n")
cat("\\node at (4, -0.3) {2};\n")
cat("\\node at (6, -0.3) {3};\n")
cat("\\node at (6.6, 0) {t};\n")
cat("% Etiqueta de Elección y flecha\n")
cat("\\node at (3, 1) {Elección};\n")
cat("\\draw[->] (3, 0.8) -- (3, 0.1);\n")
cat("\\end{tikzpicture}\n")
cat("\\end{center}\n")
# Cerrar el dispositivo TikZ
dev.off()
pdflatex grafico_tiempo.tex
